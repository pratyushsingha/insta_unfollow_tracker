# Database
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/database

# Redis (SSL required for Vultr/DigitalOcean)
REDIS_URL=rediss://default:password@host:port

# Email (Resend)
RESEND_API_KEY=re_123456789
RESEND_FROM=YourAppName <noreply@yourdomain.com>

# App Config
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NODE_ENV=development

# Apify (Instagram Scraper)
APIFY_API_TOKEN=apify_api_123456789
# APIFY_API_TOKENS=token1,token2,token3 (Optional: comma-separated for rotation)

# Security
# Generate a 32-byte key: openssl rand -hex 32
ENCRYPTION_KEY=your_32_byte_hex_encryption_key
ADMIN_SECRET_KEY=your_admin_secret_access_key

# Monitoring (Sentry)
SENTRY_DSN=https://your_sentry_dsn_url
